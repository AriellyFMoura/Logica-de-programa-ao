Algoritmo "Soma"

Var
   N1, N2, S: Inteiro

Inicio
      Escreval("Calculadora das somas")
      Escreva("Informe o primeiro numero: ")
      Leia(N1)
      Escreva("Informe o segundo numero: ")
      Leia(N2)
      S <- N1 + N2
      Escreva("A soma dos numeros", N1, " e", N2, " é igual a", S)
Fimalgoritmo